#include <stdio.h>
 
void printArray(int arr[], int n) {
  	int i;
  	for (i = 0; i < n; i++)
        	printf("%d ", arr[i]);
  	printf("\n");
}
 
int findMax(int arr[], int n) {
  	int i, max = arr[0];
  	for (i = 1; i < n; i++)
        	if (arr[i] > max) max = arr[i];
	return max;
}
 
int main() {
  	int a[] = {5, 3, 8, 1, 9, 2};
  	int n = 6;
  	printf("25331A05G3\n");
  	printf("Array: ");
  	printArray(a, n);
  	printf("Maximum = %d\n", findMax(a, n));
  	return 0;
}
