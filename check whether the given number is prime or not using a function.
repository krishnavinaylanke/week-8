#include <stdio.h>
 
int isPrime(int n) {
  	int i;
  	if (n < 2) return 0;
  	for (i = 2; i <= n / 2; i++)
        	if (n % i == 0) return 0;
  	return 1;
}
 
int main() {
  	int num;
  	printf("25331A05G3\n");
  	printf("Enter a number: ");
  	scanf("%d", &num);
  	if (isPrime(num))
        	printf("%d is Prime\n", num);else
        	printf("%d is NOT Prime\n", num);
  	return 0;
}
